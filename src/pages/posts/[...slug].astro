---
import { render, getCollection } from "astro:content";
import PostLayout from "@/layouts/BlogPost.astro";

export async function getStaticPaths() {
    const allPosts = await getCollection("post");
    
    // 日付の新しい順にソート
    const sortedPosts = allPosts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

    return sortedPosts.map((post, index) => {
        const next = index > 0 ? sortedPosts[index - 1] : null;
        const prev = index < sortedPosts.length - 1 ? sortedPosts[index + 1] : null;
        
        return {
            params: { slug: post.id },
            props: { post, prev, next },
        };
    });
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);
---

<PostLayout post={post}>
    <Content />

    <!-- ページャー部分 -->
    <nav style="display: flex; justify-content: space-between; margin-top: 3rem; padding-top: 1rem; border-top: 1px solid #ccc; font-size: 0.9rem;">
        <div>
            {prev ? (
                <a href={`/burogu/posts/${prev.id}/`} style="color: #666; text-decoration: none;">
                    &larr; 前の記事: {prev.data.title}
                </a>
            ) : <span></span>}
        </div>
        <div>
            {next ? (
                <a href={`/burogu/posts/${next.id}/`} style="color: #666; text-decoration: none;">
                    次の記事: {next.data.title} &rarr;
                </a>
            ) : <span></span>}
        </div>
    </nav>
</PostLayout>