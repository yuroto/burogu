

---
import { render, getCollection } from "astro:content";
import PostLayout from "@/layouts/BlogPost.astro";

// 1. 記事を直接取得する（シンプル化）
export async function getStaticPaths() {
    const allPosts = await getCollection("post");
    console.log("★見つけた記事数:", allPosts.length); // ターミナルに表示されるはず

    return allPosts.map((post, index) => {
        const prev = index < allPosts.length - 1 ? allPosts[index + 1] : null;
        const next = index > 0 ? allPosts[index - 1] : null;
        return {
            params: { slug: post.id },
            props: { post, prev, next },
        };
    });
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);
---

<PostLayout post={post}>
    <Content />
</PostLayout>

<div style="border: 2px solid blue; padding: 20px; margin-top: 50px;">
    <strong>デバッグ表示:</strong><br>
    前の記事: {prev ? prev.data.title : "なし"}<br>
    次の記事: {next ? next.data.title : "なし"}
</div>